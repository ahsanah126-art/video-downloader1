# Port the API listens on (Railway sets PORT automatically)
PORT=8787

# Comma-separated list of allowed origins for CORS.
# Use * for open access during development.
# Example: https://your-frontend.lovable.app,https://your-domain.com
CORS_ORIGIN=*

# Optional: override binary paths if not on PATH
# YTDLP_PATH=/usr/local/bin/yt-dlp
# FFMPEG_PATH=/usr/bin/ffmpeg

# Requests per minute per IP
RATE_LIMIT_MAX=30
